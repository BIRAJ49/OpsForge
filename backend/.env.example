APP_NAME=OpsForge
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql://opsforge:opsforge@postgres:5432/opsforge

JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=http://localhost:5173

ADMIN_EMAIL=birajadhikari49@gmail.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Biraj Admin

EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=birajadhikari49@gmail.com
RESEND_API_KEY=

GITHUB_CLIENT_MODE=token
GITHUB_TOKEN=
GITHUB_USERNAME=BIRAJ49
GITHUB_DEFAULT_BRANCH=main
GITHUB_PROJECT_REPO_FORMAT=opsforge-{project-name}
GITHUB_GITOPS_REPO=opsforge-gitops
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/github/oauth/callback
FRONTEND_URL=http://localhost:5173

GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=BIRAJ49
GHCR_TOKEN=
GHCR_IMAGE_FORMAT=ghcr.io/BIRAJ49/{project-name}:{tag}

KUBERNETES_MODE=kubeconfig
KUBECONFIG_PATH=
KUBERNETES_CONTEXT=opsforge-k3d
KUBERNETES_LOCAL_CLUSTER=opsforge
KUBERNETES_DEFAULT_NAMESPACE=opsforge
KUBERNETES_PRODUCTION_NAMESPACE=opsforge-prod
KUBERNETES_PRODUCTION_TYPE=k3s-ec2

ARGOCD_SERVER=
ARGOCD_TOKEN=
ARGOCD_USERNAME=
ARGOCD_PASSWORD=
ARGOCD_NAMESPACE=argocd
ARGOCD_APP_FORMAT={project-name}-{environment}
ARGOCD_AUTO_SYNC=true
ARGOCD_PRUNE=true
ARGOCD_SELF_HEAL=true

AI_PROVIDER=rule_based
AI_ENABLED=false
PROJECT_ANALYZER_MODE=rule_based
MAX_UPLOAD_SIZE_MB=500
MAX_UPLOAD_FILE_SIZE_MB=100
UPLOAD_TEMP_DIR=/tmp/opsforge-uploads
DELETE_UPLOAD_AFTER_ANALYSIS=true
ALLOW_GITHUB_IMPORT=true
ALLOW_ZIP_UPLOAD=true

MONITORING_MODE=mock

TRIVY_ENABLED=true
TRIVY_PATH=trivy

REDIS_URL=redis://redis:6379/0
